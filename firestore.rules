rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'role', 'updatedAt']) 
        && data.keys().size() == 4
        && data.displayName is string && data.displayName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 1000000
        && data.role in ['member', 'admin']
        && data.updatedAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'userName', 'userAvatar', 'text', 'rating', 'createdAt'])
        && data.keys().size() == 6
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.userAvatar is string && data.userAvatar.size() <= 2000
        && data.text is string && data.text.size() <= 1000
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.createdAt == request.time;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'caption', 'createdAt'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.imageUrl is string && data.imageUrl.size() <= 1000000
        && data.caption is string && data.caption.size() <= 200
        && data.createdAt == request.time;
    }

    // Collection Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow delete: if isOwner(existing().userId);
    }

    match /photos/{photoId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPhoto(incoming());
      allow delete: if isOwner(existing().userId);
    }
  }
}
